<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.emam.bankingsheba.controller.Dashboard">
    <top>
        <HBox spacing="12" padding="12" alignment="CENTER_LEFT">
            <Label fx:id="welcomeLabel" text="Welcome," style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="balanceLabel" text="Balance: 0.00" style="-fx-font-size: 16px;" />
            <Button fx:id="logoutButton" text="Logout" onAction="#onLogout" />
        </HBox>
    </top>
    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12" />
            </padding>

            <HBox spacing="12">
                <Button fx:id="addButton" text="Add Money" onAction="#onAdd" prefWidth="140" />
                <Button fx:id="withdrawButton" text="Withdraw" onAction="#onWithdraw" prefWidth="140" />
                <Button fx:id="historyButton" text="Transactions" onAction="#onHistory" prefWidth="140" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
