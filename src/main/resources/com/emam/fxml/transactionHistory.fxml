<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.emam.bankingsheba.controller.TransactionController" spacing="10" padding="12">
    <Label text="Transaction History" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
    <TableView fx:id="table" prefHeight="320">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="60" />
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="120" />
            <TableColumn fx:id="amountColumn" text="Amount" prefWidth="120" />
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="260" />
        </columns>
    </TableView>
    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="backButton" text="Back" onAction="#onBack" />
    </HBox>
</VBox>
